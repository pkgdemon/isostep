#!/bin/sh

. /Developer/Makefiles/GNUstep.sh

# GLOBAL SETTINGS
defaults write NSGlobalDomain GSBackHandlesWindowDecorations 0
defaults write NSGlobalDomain NSInterfaceStyleDefault NSMacintoshInterfaceStyle
defaults write NSGlobalDomain GSFileBrowserHideDotFiles YES

# GWORKSPACE SETTINGS
defaults write GWorkspace terminal_services YES
defaults write GWorkspace dockclickpolicy 1
defaults write GWorkspace dockposition 0

openapp GWorkspace
